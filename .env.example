# ─────────────────────────────────────────────────────────────
# Supabase
# Project Settings → API
# ─────────────────────────────────────────────────────────────
# Safe to expose to the browser:
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# SERVER ONLY — never expose to the browser. Bypasses Row Level Security.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─────────────────────────────────────────────────────────────
# API-Football  (https://www.api-football.com/)
# SERVER ONLY — never expose to the browser.
# ─────────────────────────────────────────────────────────────
API_FOOTBALL_KEY=your-api-football-key

# Use the host that matches your subscription:
#   Direct (api-sports.io):  v3.football.api-sports.io
#   Via RapidAPI:            api-football-v1.p.rapidapi.com
API_FOOTBALL_HOST=v3.football.api-sports.io

# World Cup league id is 1 in API-Football. Override per tournament/season.
API_FOOTBALL_LEAGUE_ID=1
API_FOOTBALL_SEASON=2026
